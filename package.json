{
  "name": "emergency-centre",
  "private": false,
  "version": "1.0.0",
  "description": "Open-source public multi-signal monitoring app and reusable Node provider library for live coverage feeds.",
  "license": "AGPL-3.0-or-later",
  "funding": "https://ko-fi.com/ninezel",
  "homepage": "https://github.com/Ninezel/emergency-centre#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ninezel/emergency-centre.git"
  },
  "bugs": {
    "url": "https://github.com/Ninezel/emergency-centre/issues"
  },
  "keywords": [
    "emergency",
    "monitoring",
    "weather",
    "alerts",
    "scraper",
    "civic-tech",
    "node-library"
  ],
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "./dist-server/server/library/index.js",
  "types": "./dist-server/server/library/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-server/server/library/index.d.ts",
      "import": "./dist-server/server/library/index.js"
    },
    "./catalog": {
      "types": "./dist-server/server/library/catalog.d.ts",
      "import": "./dist-server/server/library/catalog.js"
    },
    "./providers": {
      "types": "./dist-server/server/library/providers.d.ts",
      "import": "./dist-server/server/library/providers.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist-server",
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "docs"
  ],
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "tsc && vite build && tsc -p tsconfig.server.json",
    "build:client": "tsc && vite build",
    "build:api": "tsc -p tsconfig.server.json",
    "start:api": "node dist-server/server/index.js",
    "preview": "vite preview",
    "prepare": "npm run build:api",
    "test": "vitest run"
  },
  "dependencies": {
    "express": "^5.1.0",
    "fast-xml-parser": "^5.5.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.6.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
